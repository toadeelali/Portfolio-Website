{
  "name": "theadeel.com",
  "version": "1.1.0",
  "private": true,
  "description": "It's Adeel Ali",
  "author": {
    "name": "Adeel Ali",
    "email": "wikz@live.com",
    "url": "https://theadeel.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wikz/Portfolio-Website.git"
  },
  "dependencies": {
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-redux": "^7.2.4",
    "smoothscroll-polyfill": "^0.4.4"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@commitlint/cli": "^12.1.4",
    "@commitlint/config-conventional": "^12.1.4",
    "@semantic-release/changelog": "^5.0.1",
    "@semantic-release/commit-analyzer": "^8.0.1",
    "@semantic-release/git": "^9.0.0",
    "@testing-library/jest-dom": "^5.13.0",
    "@testing-library/react": "^11.2.7",
    "@testing-library/user-event": "^13.1.9 ",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.19.0",
    "@types/react": "^17.0.9",
    "@types/react-dom": "^17.0.6",
    "@types/react-redux": "^7.1.16",
    "@types/redux-mock-store": "^1.0.2",
    "@types/smoothscroll-polyfill": "^0.3.1",
    "@typescript-eslint/eslint-plugin": "^4.26.0",
    "@typescript-eslint/parser": "^4.26.0",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-eslint": "10.x",
    "babel-jest": "^29.7.0",
    "babel-plugin-transform-import-meta": "^3.0.0",
    "cross-env": "^7.0.3",
    "eslint": "^7.x",
    "eslint-config-react-app": "^6.0.0",
    "eslint-plugin-flowtype": "^5.7.2",
    "eslint-plugin-import": "^2.23.4",
    "eslint-plugin-jsx-a11y": "^6.4.1",
    "eslint-plugin-no-null": "^1.0.2",
    "eslint-plugin-react": "^7.24.0",
    "eslint-plugin-react-hooks": "^4.2.0",
    "husky": "^6.0.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "jest-fetch-mock": "^3.0.3",
    "lint-staged": "^11.0.0",
    "prettier": "^2.3.1",
    "redux": "^4.1.0",
    "redux-mock-store": "^1.5.4",
    "sass": "^1.0.0",
    "semantic-release": "^17.4.3",
    "typescript": "^5.9.3",
    "vite": "^8.1.3",
    "vite-plugin-svgr": "^4.0.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "npm run format",
      "eslint --ext .js,.jsx,.ts,.tsx --fix-dry-run"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "build:local": "npm run build && vite preview",
    "test": "jest --silent --verbose",
    "test:watch": "jest --watch",
    "format": "prettier --write **/*.{js,jsx,.ts,.tsx,json}",
    "lint": "eslint --ext .js,.jsx,.ts,.tsx .",
    "release": "semantic-release",
    "release:local": "semantic-release --no-ci --dry-run",
    "ci:action-trigger": "bash ./scripts/trigger-github-action.sh",
    "pre-commit": "lint-staged"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFiles": [
      "./src/setupTests.ts"
    ],
    "moduleNameMapper": {
      "\\.(css|scss|sass)$": "identity-obj-proxy",
      "\\.svg\\?react$": "<rootDir>/__mocks__/svgReactMock.js",
      "\\.(jpg|jpeg|png|gif|webp|svg)$": "<rootDir>/__mocks__/fileMock.js"
    },
    "transform": {
      "^.+\\.(t|j)sx?$": "babel-jest"
    },
    "moduleDirectories": [
      "node_modules",
      "src"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(smoothscroll-polyfill)/)"
    ]
  }
}
